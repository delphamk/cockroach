{
	"name": "crdb dev container",
	"image": "mcr.microsoft.com/devcontainers/base:noble",
	"features": {
		"ghcr.io/devcontainers/features/common-utils:2": {},
		"ghcr.io/devcontainers-community/features/bazel:1": {},
		"ghcr.io/devcontainers/features/go:1": {},
		"ghcr.io/devcontainers/features/sshd:1": {
			"version": "latest"
		},
		"ghcr.io/devcontainers/features/nix:1": {},
		"ghcr.io/devcontainers-extra/features/actionlint:1": {}
	},
	"runArgs": [
		"--add-host=host.docker.internal:host-gateway"
	],
	"containerEnv": {
		"SHELL": "/bin/zsh"
	},
	"postCreateCommand": "echo 'build --remote_cache=http://host.docker.internal:9090\ntest --remote_cache=http://host.docker.internal:9090' > ~/.bazelrc && /home/vscode/dots/install-home-manager && /home/vscode/dots/setup",
	"mounts": [
		"source=${localEnv:HOME}/dots,target=/home/vscode/dots,type=bind,consistency=cached"
	],
	"forwardPorts": [9999],
    "portsAttributes": {
        "9999": {
            "label": "CockroachDB"
        }
    }
}